# LANAgent Environment Configuration
# Copy this file to .env and fill in your values
# Or run: ./scripts/setup/install.sh to generate automatically

# ===========================================
# CORE CONFIGURATION (Required)
# ===========================================

# Agent Identity
AGENT_NAME=MyAgent
AGENT_PORT=3000
AGENT_SSH_PORT=2222
# AGENT_HOST=  # Optional — auto-detected from network interfaces if not set

# AI Providers (at least one required)
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
# GAB_AI_API_KEY=your-gab-key
# XAI_API_KEY=your-xai-key
# HUGGINGFACE_TOKEN=your-hf-token
# UNCENSORED_API_KEY=your-uncensored-ai-key
ANTHROPIC_ENABLE_WEB_SEARCH=true

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lanagent

# Master Identity
EMAIL_OF_MASTER=your-email@example.com
# Optional: phone number for SMS calendar reminders (E.164 format, e.g. +15551234567)
PHONE_OF_MASTER=
# Optional: FCM registration token for push calendar reminders
FCM_TOKEN_OF_MASTER=

# Security (auto-generated by install script if empty)
JWT_SECRET=
ENCRYPTION_KEY=
WEB_UI_PASSWORD=lanagent

# ===========================================
# OPTIONAL: Ollama (Local AI — free, private)
# ===========================================
# Run any model locally: llama3.1, mistral, codellama, etc.
# Install: https://ollama.ai  |  Pull a model: ollama pull llama3.1
# Can run on this machine or a remote GPU box on your LAN.
# ENABLE_OLLAMA=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_VISION_MODEL=llava

# ===========================================
# OPTIONAL: BitNet (Local CPU 1-bit LLM)
# ===========================================
# Ultra-lightweight — runs on Raspberry Pi, no GPU needed.
# ENABLE_BITNET=true
# BITNET_BASE_URL=http://localhost:8080
# BITNET_CHAT_MODEL=BitNet-b1.58-2B-4T
# BITNET_CONTEXT_LENGTH=2048

# ===========================================
# OPTIONAL: Telegram Bot
# ===========================================
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_USER_ID=your-telegram-id

# ===========================================
# OPTIONAL: Email (SMTP)
# ===========================================
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASS=your-app-password

# ===========================================
# Self-Modification / Git (enabled by default)
# ===========================================
GIT_PERSONAL_ACCESS_TOKEN=your-git-token
GITHUB_REPO=https://github.com/YOUR_USER/LANAgent
AGENT_REPO_PATH=.
UPSTREAM_REPO=https://github.com/PortableDiag/LANAgent
UPSTREAM_CONTRIBUTIONS=true

# ===========================================
# OPTIONAL: SSH Interface
# ===========================================
SSH_USERNAME=lanagent
SSH_PASSWORD=changeme

# ===========================================
# OPTIONAL: Deployment
# ===========================================
# DEPLOY_PATH=/path/to/deployment
# PRODUCTION_SERVER=your-server-ip
# PRODUCTION_USER=root
# PRODUCTION_PASSWORD=your-password

# ===========================================
# OPTIONAL: Paths (defaults to project root)
# ===========================================
# DATA_PATH=./data
# LOGS_PATH=./logs
# WORKSPACE_PATH=./workspace

# ===========================================
# P2P Skynet Network (enabled by default)
# ===========================================
P2P_ENABLED=true
P2P_DISPLAY_NAME=MyAgent
# P2P_REGISTRY_URL=wss://registry.lanagent.net
AGENT_SERVICE_URL=http://your-public-ip:3000  # Public URL so other agents can reach you

# ===========================================
# Email Lease Service (genesis instances only)
# Enables leasing @lanagent.net email addresses to fork instances via P2P
# ===========================================
# EMAIL_LEASE_ENABLED=true
# MAIL_API_URL=http://your-mail-server:9100
# MAIL_API_SECRET=your-64-char-hex-secret

# ===========================================
# OPTIONAL: Browser (Puppeteer)
# ===========================================
# Uses system Chromium by default. Set these if you need a custom path.
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# ===========================================
# OPTIONAL: Advanced
# ===========================================
ENABLE_VECTOR_INTENT=true
# EXPRESSVPN_ENABLED=false
# PYTHON_PATH=/usr/bin/python3

# ===========================================
# DEX AGGREGATOR
# ===========================================
# ONEINCH_API_KEY=              # 1inch API key from https://portal.1inch.dev (optional, improves rate limits)

# ===========================================
# 3D AVATAR / VR
# ===========================================
# MESHY_API_KEY=                 # Meshy.ai API key for photo/text-to-3D model generation
# TRIPO_API_KEY=                 # Tripo3D API key (alternative 3D generation provider)
# AVATAR_NFT_CONTRACT_ADDRESS=   # AvatarNFT contract address (set after deployment)
# ORACLE_CONTRACT_ADDRESS=       # AgentCouncilOracle contract address (set after deployment)
# NFT_STORAGE_API_KEY=           # nft.storage API key for IPFS pinning (optional, free tier)

# ===========================================
# SCRAPING — RENDER TIER (FlareSolverr)
# ===========================================
# FlareSolverr is a Cloudflare bypass proxy used by the scraper plugin's
# render tier. Run it locally as a Docker container:
#   docker run -d --name flaresolverr --restart unless-stopped \
#     -p 127.0.0.1:8191:8191 --shm-size=2g \
#     ghcr.io/flaresolverr/flaresolverr:latest
# If unset, the scraper falls back to Puppeteer (which fails on managed
# Cloudflare challenges like Rumble's).
# FLARESOLVERR_URL=http://127.0.0.1:8191/v1

# ===========================================
# PLUGIN API KEYS
# ===========================================
# Plugin-specific API keys are stored encrypted in MongoDB.
# Configure them via the web UI: Settings > Plugins > [Plugin] > Credentials tab
#
# Supported plugins with configurable credentials:
# - HERE Maps (location services)
# - NASA (space data and imagery)
# - VirusTotal (malware scanning)
# - Govee (smart home lighting)
# - News API (news aggregation)
# - Alpha Vantage (stock market data)
# - CoinGecko (crypto data)
# - And many more — see web UI for full list


# Voice Interaction Settings
# Set VOICE_AUTOSTART=true to auto-start voice listening on launch
VOICE_AUTOSTART=false
# Audio device card number (run 'aplay -l' to list devices)
VOICE_AUDIO_DEVICE=
VOICE_OUTPUT_DEVICE=

# Email Configuration
# Supported providers: gmail, outlook, hotmail, fastmail, custom
EMAIL_PROVIDER=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
# For custom provider only:
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993

# Gravatar API (optional - enriches email contacts with profile data)
# Get your API key at https://gravatar.com/developers/
# Without API key, basic avatar URLs still work
GRAVATAR_API_KEY=

# Gravatar OAuth2 (for avatar upload via WordPress.com OAuth)
# Create an app at https://gravatar.com/developers/ to get these
GRAVATAR_CLIENT_ID=
GRAVATAR_CLIENT_SECRET=

# ERC-8004 Agent Identity (Pinata IPFS for avatar/registration hosting)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Calendar Configuration
# Set to true to use local MongoDB calendar only (no CalDAV sync)
CALENDAR_LOCAL_ONLY=true
# Optional: CalDAV credentials (only used if CALENDAR_LOCAL_ONLY=false)
# CALENDAR_USERNAME=your-email@provider.com
# CALENDAR_APP_PASSWORD=your-app-password
# CALENDAR_SERVER_URL=https://caldav.provider.com/

# Ollama (Local LLMs) - No API key required
# Install Ollama from https://ollama.ai then run: ollama serve
# Pull models with: ollama pull mistral
ENABLE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=llava

# Git Hosting Provider (for self-modification and PR operations)
# Supported providers: github, gitlab
GIT_HOSTING_PROVIDER=github

# GitHub Configuration (default)
# Get a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo, read:org (for private repos)
GITHUB_TOKEN=ghp_your_github_token_here
# Optional: Override auto-detected owner/repo
# GITHUB_OWNER=your-username
# GITHUB_REPO=your-repo

# GitLab Configuration (alternative to GitHub)
# Get a Personal Access Token at: https://gitlab.com/-/user_settings/personal_access_tokens
# Required scopes: api, read_repository, write_repository
# GITLAB_TOKEN=glpat_your_gitlab_token_here
# GITLAB_URL=https://gitlab.com
# GITLAB_PROJECT_ID=owner/repo

# Legacy setting (still supported, maps to GITHUB_TOKEN)
# GIT_PERSONAL_ACCESS_TOKEN=ghp_your_token_here
